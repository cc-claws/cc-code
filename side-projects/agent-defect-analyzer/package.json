    "analyze:strategy": "bun run src/main.ts --focus strategy",
    "analyze:ux": "bun run src/main.ts --focus ux",
    "analyze:semantic": "bun run src/main.ts --focus semantic",
    "analyze:cluster": "bun run src/main.ts --focus cluster",
    "analyze:tools": "bun run src/main.ts --focus tools",
